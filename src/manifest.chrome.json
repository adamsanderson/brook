{
  "manifest_version": 3,
  "name": "Brook Feed Reader",
  "version": "0.6.0",
  "author": "Adam Sanderson <netghost@gmail.com>",
  "icons": {
    "96": "icons/Brook-96.png",
    "48": "icons/Brook-48.png"
  },

  "side_panel": {
    "default_path": "src/Sidebar/index.html"
  },

  "action": {
    "default_icon": {
      "96": "icons/Brook-96.png",
      "48": "icons/Brook-48.png"
    },
    "default_title": "Brook"
  },

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],

  "permissions": ["alarms", "sidePanel", "storage", "unlimitedStorage"],

  "host_permissions": ["<all_urls>"]
}
