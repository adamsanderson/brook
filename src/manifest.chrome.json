{
  "manifest_version": 3,
  "name": "Brook Feed Reader",
  "version": "0.6.0",
  "author": "Adam Sanderson <netghost@gmail.com>",

  "side_panel": {
    "default_path": "src/Sidebar/index.html"
  },

  "action": {
    "default_icon": {
      "96": "icons/Brook.svg",
      "48": "icons/Brook.svg"
    },
    "default_title": "Brook"
  },

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "options_ui": {
    "page": "src/Options/index.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],

  "permissions": [
    "alarms",
    "sidePanel",
    "storage",
    "unlimitedStorage"
  ],

  "host_permissions": [
    "<all_urls>"
  ]
}
