{
  "manifest_version": 3,
  "name": "Brook Feed Reader",
  "version": "0.6.0",
  "author": "Adam Sanderson <netghost@gmail.com>",

  "sidebar_action": {
    "default_icon": {
      "96": "icons/Brook.svg",
      "48": "icons/Brook.svg"
    },
    "default_title": "Brook",
    "default_panel": "src/Sidebar/index.html"
  },

  "action": {
    "default_icon": {
      "96": "icons/Brook.svg",
      "48": "icons/Brook.svg"
    },
    "default_title": "Brook"
  },

  "background": {
    "scripts": ["src/background/index.ts"]
  },

  "options_ui": {
    "page": "src/Options/index.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],

  "permissions": [
    "alarms",
    "storage",
    "unlimitedStorage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "{e22ef003-e424-45f0-9da1-b0b93617ce49}"
    }
  }
}
